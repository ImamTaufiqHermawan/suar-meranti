# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role — WAJIB untuk fitur hapus aspirasi admin (server-only, jangan expose ke client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session admin — generate string random min. 32 karakter
ADMIN_SESSION_SECRET=your-random-secret-min-32-characters-long

# App URL (gunakan URL production setelah deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only — sudah otomatis diaktifkan lewat `npm run dev` (lihat package.json)
# ALLOW_INSECURE_SSL=true
