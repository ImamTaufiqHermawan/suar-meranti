# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL (gunakan URL production setelah deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only — sudah otomatis diaktifkan lewat `npm run dev` (lihat package.json)
# Tidak perlu di-set manual kecuali menjalankan `next dev` langsung
# ALLOW_INSECURE_SSL=true
